<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Non-sandboxed: the app needs unrestricted FSEvents watching and free
	     access to arbitrary local/NAS destinations. Full Disk Access (TCC) is
	     requested at runtime for reading protected source folders. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
